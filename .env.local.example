# Copy to .env.local and fill in values before running.

# Supabase (self-hosted)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.sdrc.in
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Port override (default: 3010)
# PORT=3010

# Protocol for internal Puppeteer PDF rendering (default: http — do not change to https on self-hosted)
# RENDER_PROTO=http
